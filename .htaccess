<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # -------------------------------------------------------------------
    # Assets from Sitejet (css, js, images, webcard, g)
    # These exist directly in devlp/ — serve as-is without touching Laravel
    # -------------------------------------------------------------------
    RewriteCond %{REQUEST_URI} ^/(css|js|images|webcard|g|modules-1|expertise|portfolio|projects|get-in-touch|blog-single-page-layout|jobs-1-item|legal-notice|privacy|subpage|real-estate-single-page-layout)/
    RewriteRule ^ - [L]

    # -------------------------------------------------------------------
    # Laravel — route everything else through public/index.php
    # (We placed index.php in root and adjusted paths below)
    # -------------------------------------------------------------------
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?$1 [QSA,L]
</IfModule>
