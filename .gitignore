# Laravel .gitignore

# Environment
.env
.env.backup
.env.production
.env.testing

# Dependencies
/vendor
/node_modules

# Composer
composer.lock (opsional - jika ingin lock version)

# IDE
.idea/
.vscode/
*.sublime-*

# OS
.DS_Store
Thumbs.db

# Runtime
*.log
*.sqlite

# Laravel specific
/storage/*.key
/storage/logs/*.log
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*

# Temporary
/cache/
/temp/

# Public uploads (jika ada)
/public/uploads/

# Database backups
/*.sql
*.sql.gz
