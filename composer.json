{
    "name": "sixer0/landing-laravel",
    "description": "Laravel 11 + Bootstrap Portfolio Landing Page",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^7.4 || ^8.1 || ^8.5",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
        ],
        "test:env": "php scripts/check_environment.php",
        "test:db": "php scripts/check_database.php",
        "test:login": "php tests/e2e/login_flow_test.php"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
